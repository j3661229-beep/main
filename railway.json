{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd agrimart-backend && npm install && npm run build"
    },
    "deploy": {
        "startCommand": "cd agrimart-backend && npm start",
        "healthcheckPath": "/api/health",
        "restartPolicyType": "ON_FAILURE"
    }
}