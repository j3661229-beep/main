# ============================================================
# AgriMart Backend — Environment Variables
# ============================================================

# ── Database ────────────────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:[PORT]/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:[PORT]/postgres"

# ── Supabase ────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_STORAGE_BUCKET=agrimart-images

# ── JWT Auth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin ───────────────────────────────────────────────────
# Phone stored in DB, password checked here
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE

# ── Twilio (WhatsApp OTP) ───────────────────────────────────
# Get from: https://console.twilio.com
# Use WhatsApp Sandbox for dev: +14155238886
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Razorpay ────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use test keys for development (prefix: rzp_test_)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# ── Google Gemini (AI features) ─────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Weather API ─────────────────────────────────────────────
# Get from: https://openweathermap.org/api (free tier works)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_KEY_HERE
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── Mandi Prices (AGMARKNET) ────────────────────────────────
# Get from: https://data.gov.in → Register → Get API key
AGMARKNET_API_URL=https://api.data.gov.in/resource
AGMARKNET_API_KEY=YOUR_AGMARKNET_KEY_HERE

# ── Redis (Caching & Rate Limiting) ─────────────────────────
# Get from: https://upstash.com → Create Redis → REST URL & Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── OneSignal (Push Notifications) ──────────────────────────
# Get from: https://onesignal.com → Settings → Keys & IDs
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Business Config ─────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.025
FREE_DELIVERY_ABOVE=500
C